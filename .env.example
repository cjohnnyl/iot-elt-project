# ============================================================
# IOT-ELT-PROJECT — Template de Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env
# ============================================================

# --- Kafka ---
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=iot_sensors

# --- PostgreSQL ---
POSTGRES_USER=seu_usuario
POSTGRES_PASSWORD=sua_senha_segura
POSTGRES_DB=iot_data
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Producer ---
# Lista de estufas separadas por vírgula (sem espaços)
ESTUFAS=EUCALIPTO_01,EUCALIPTO_02,EUCALIPTO_03
# Intervalo entre mensagens em segundos (padrão: 3)
SENSOR_INTERVAL_SECONDS=3

# --- API ---
API_PORT=8000
# Temperatura aceitável: 22°C a 30°C
ALERT_TEMP_MIN=22.0
ALERT_TEMP_MAX=30.0
# Umidade aceitável: 50% a 80%
ALERT_HUMIDITY_MIN=50.0
ALERT_HUMIDITY_MAX=80.0

# --- Ollama (LLM local — sem internet) ---
# Modelo disponível: llama3.2, phi3, mistral, etc.
# Na primeira execução o modelo será baixado (~2GB)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Acesse em: http://localhost:3000
